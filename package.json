{
	"name": "simon-web-refactor",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"lint": "eslint .",
		"build": "tsc -b && vite build",
		"build:dev": "npm run build -- --mode development",
		"build:mf:watch": "npm run build:dev -- --watch",
		"preview": "vite preview",
		"preview:mf": "npm run preview -- --port 5174 --strictPort",
		"mf:watch": "npm run build:mf:watch & npm run preview:mf",
		"deploy": "npm run build && aws s3 sync dist/ s3://simon-dev-refactor-guantera --delete",
		"invalidate": "aws cloudfront create-invalidation --distribution-id E178YAA72SMNW0 --paths '/*'",
		"deploy-full": "npm run deploy && npm run invalidate"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.6",
		"@mui/material": "^7.3.6",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@originjs/vite-plugin-federation": "^1.4.1",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"autoprefixer": "^10.4.22",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.17",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.4",
		"vite": "^7.2.4"
	}
}
